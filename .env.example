# Magimatix site — environment variables (template; no real secrets here)
# Copy to .env.local and fill in. In production, set these in Vercel.

# Image generation for blog post hero images
FAL_KEY=

# ── Stripe — DATA Dashboard direct checkout ──────────────────────────────────
# Server secret key (sk_live_… in prod, sk_test_… locally)
STRIPE_SECRET_KEY=
# Publishable key, exposed to the browser for embedded checkout (pk_live_/pk_test_)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Price ID for the DATA product, e.g. price_1Q...
STRIPE_DATA_PRICE_ID=
# Webhook signing secret, whsec_...
STRIPE_WEBHOOK_SECRET=
# Absolute URL of the cross-platform product zip on Vercel Blob (private).
# Served to all buyers; the default download (Windows / macOS / Linux).
DATA_DOWNLOAD_URL=
# Absolute URL of the Windows one-click installer (.exe) on Vercel Blob (private).
# Served via /api/download?format=installer for Windows buyers. Optional — if
# unset, the installer button returns "not configured" and the zip still works.
DATA_INSTALLER_URL=
# "true" only once Stripe Tax + registrations are configured
STRIPE_AUTOMATIC_TAX=false

# ── Vercel Blob ──────────────────────────────────────────────────────────────
# Read/write token for uploading the product zip (build/script use only)
BLOB_READ_WRITE_TOKEN=

# ── Resend — transactional email (DATA Daemon download delivery) ─────────────
# API key from the Resend account where the sending domain is VERIFIED. A key
# from a different account is silently rejected — nothing is delivered.
RESEND_API_KEY=
# Display-name + mailbox on the verified sending domain, e.g.
# "DATA Daemon <daemon@send.magimatix.com>". Defaults to that if unset.
RESEND_FROM=
# Optional reply-to address (e.g. a support inbox). Omit to disable.
RESEND_REPLY_TO=
# Canonical site origin used to build emailed links. Defaults to
# https://magimatix.com if unset.
SITE_URL=
